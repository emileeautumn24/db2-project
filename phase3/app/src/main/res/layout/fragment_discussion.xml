<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Discussion Board"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/discCourseIdInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Course ID"
        android:inputType="number"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/discSectionIdInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Section ID"
        android:inputType="number"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/discSemesterInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Semester (e.g. Spring)"
        android:inputType="text"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/discYearInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Year (e.g. 2026)"
        android:inputType="number"
        android:layout_marginBottom="16dp"/>

    <!-- Post input - for enrolled students -->
    <EditText
        android:id="@+id/postContentInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Write your post here..."
        android:inputType="textMultiLine"
        android:minLines="2"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/postButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Post"
        android:layout_marginBottom="16dp"/>

    <!-- Delete section - only visible to TA/Grader -->
    <TextView
        android:id="@+id/deleteLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete a student post (TA/Grader only):"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/deleteStudentIdInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Student ID whose post to delete"
        android:inputType="number"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/roleRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <RadioButton
            android:id="@+id/taRadioButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TA" />

        <RadioButton
            android:id="@+id/graderRadioButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grader" />

    </RadioGroup>

    <Button
        android:id="@+id/deletePostButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete Post"
        android:layout_marginBottom="16dp"/>

    <!-- Results display -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/discussionPostsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"/>
    </ScrollView>

    <TextView
        android:id="@+id/discResultText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"/>

    <Button
        android:id="@+id/discBackButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back"
        android:layout_marginTop="8dp"/>

</LinearLayout>
